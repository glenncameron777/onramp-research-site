---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reports = await getCollection('reports');
---

<BaseLayout
  title="Institutional Research | Onramp Bitcoin"
  description="In-depth research reports on Bitcoin as a strategic asset for institutional investors including family offices, endowments, pensions, sovereign wealth funds, and RIAs."
>
  <header class="hero">
    <div class="hero-nav">
      <a href="/" class="hero-logo">
        <img src="/onramp-logo-white.svg" alt="Onramp Bitcoin" />
      </a>
    </div>
    <div class="hero-content">
      <span class="hero-label">Research Library</span>
      <h1>Institutional Research</h1>
      <p class="hero-subtitle">In-depth analysis of Bitcoin as a strategic asset for institutional investors</p>
    </div>
  </header>

  <div style="max-width:1200px;margin:0 auto;padding:60px 40px 120px;">
    <div class="research-grid">
      {reports.map((report) => (
        <a href={`/research/${report.data.slug}`} class="report-card">
          <div class="report-card-header">
            <div style="display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;">
              <div class="report-card-category">{report.data.category}</div>
              <div class="report-card-date-badge">{report.data.date}</div>
            </div>
          </div>
          <div class="report-card-body">
            <h3>{report.data.title}</h3>
            {report.data.subtitle && (
              <div class="report-card-subtitle">{report.data.subtitle}</div>
            )}
          </div>
          <div class="report-card-footer">
            <div class="report-card-meta">
              <span>
                <svg class="meta-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="1.5" width="10" height="13" rx="1.5"/><line x1="5.5" y1="5" x2="10.5" y2="5"/><line x1="5.5" y1="7.5" x2="10.5" y2="7.5"/><line x1="5.5" y1="10" x2="8.5" y2="10"/></svg>
                {report.data.pages} pages
              </span>
              <span class="meta-divider"></span>
              <span>
                <svg class="meta-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8,4.5 8,8 10.5,9.5"/></svg>
                {report.data.readTime}
              </span>
            </div>
            <div class="report-card-action">
              Read
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="8" x2="13" y2="8"/><polyline points="9,4 13,8 9,12"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
