---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reports = await getCollection('reports');
---

<BaseLayout
  title="Onramp Bitcoin | Institutional Research"
  description="Research and education on Bitcoin as a strategic asset for institutional investors. In-depth reports for family offices, endowments, pensions, sovereign wealth funds, and RIAs."
>
  <header class="hero">
    <div class="hero-nav">
      <a href="/" class="hero-logo">
        <img src="/onramp-logo-white.svg" alt="Onramp Bitcoin" />
      </a>
    </div>
    <div class="hero-content">
      <span class="hero-label">Onramp Bitcoin</span>
      <h1>Institutional Research &amp; Education</h1>
      <p class="hero-subtitle">Rigorous analysis of Bitcoin as a strategic asset for institutional investors</p>
      <a href="/research" class="hero-cta">Explore Research &darr;</a>
    </div>
  </header>

  <div style="max-width:1200px;margin:0 auto;padding:60px 40px 120px;">
    <div style="margin-bottom:48px;">
      <h2>Featured Reports</h2>
      <p style="color:var(--slate-light);max-width:600px;margin-top:12px;">
        Each report examines the case for a measured Bitcoin allocation within a specific institutional context — from family offices to pension schemes to RIA practices.
      </p>
    </div>

    <div class="research-grid">
      {reports.map((report) => (
        <a href={`/research/${report.data.slug}`} class="report-card">
          <div class="report-card-category">{report.data.category}</div>
          <h3>{report.data.title}</h3>
          {report.data.subtitle && (
            <div class="report-card-subtitle">{report.data.subtitle}</div>
          )}
          <div class="report-card-meta">
            <span>{report.data.date}</span>
            <span>{report.data.pages} pages</span>
            <span>{report.data.readTime}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
